{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Persistent Sage",
  "version": "0.2.0-beta.9",
  "identifier": "app.persistentsage.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Persistent Sage",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Persistent Sage",
        "url": "splashscreen.html",
        "width": 520,
        "height": 410,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "github-updater"],
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$DATA/**", "$APPDATA/**", "$APPLOCALDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREODEwMUZDNDA4OEQ1RTAKUldUZzFZaEEvQUdCVFhKNHdGQ1MzdTlRSE1oQ3o0b2ZyUXYzOFNTMUdoa0MrZXA1WmwyWjkyOE0K",
      "endpoints": [
        "https://github.com/g00siferdev-py/persistent-sage/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
