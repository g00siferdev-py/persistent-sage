{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "store-msix",
  "description": "Microsoft Store MSIX build: same IPC as default, without Tauri GitHub updater.",
  "windows": ["main"],
  "permissions": [
    "nova-invoke-allowlist",
    "dialog:default",
    "process:allow-restart",
    "core:path:default",
    "core:window:default",
    "core:webview:default",
    "core:resources:default",
    "core:image:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten"
  ]
}
