{
  "name": "persistent-sage",
  "private": true,
  "version": "0.2.0-beta.8",
  "description": "Persistent Sage — local-first AI companion desktop app (Tauri + React)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "branding:nsis": "node scripts/generate-nsis-branding.mjs",
    "branding:icons": "npx tauri icon packaging/branding/SageIcon1024.png -o src-tauri/icons",
    "updater:manifest": "node scripts/generate-updater-manifest.mjs",
    "build:windows-installer": "npm run build && tauri build -- --bundles nsis",
    "package:portable": "node scripts/package-portable.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
